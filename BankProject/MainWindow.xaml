<Window x:Class="BankProject.MainWindow" ResizeMode="NoResize"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:BankProject"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Foreground="{DynamicResource Theme_TextBrush}" Height="526" Width="938">

    <Grid Background="{DynamicResource Theme_BackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid Background="#FFF0F0F0" Margin="8,40,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Width="288" Height="408" >
            <TextBlock FontSize="23" Margin="64,8,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Text="New Account" />
            <TextBox Text="" Margin="48,80,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Width="176" Height="32" Name="TBFirstName" />
            <TextBox Text="" Margin="48,136,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Width="176" Height="32" Name="TBLastName" />
            <TextBox Margin="48,192,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Width="176" Height="32" FontSize="13" Name="UpDownBalance" />
            <TextBlock FontSize="14" Margin="47,64,162,0" VerticalAlignment="Top" Height="24" Text="First Name" Name="TFirstName" />
            <TextBlock Text="Last Name" FontSize="14" Margin="47,120,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Height="24" Name="TLastName" />
            <TextBlock Text="Balance" FontSize="14" Margin="47,176,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Height="24" Name="TBalance" />
            <RadioButton Content="Checking Account" Margin="48,256,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Width="152" Height="32" Name="RBCheckAcc" />
            <RadioButton Content="Savings Account" Margin="48,288,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Width="152" Height="32" Name="RBSavAcc" />
            <Button Content="Create New Account" Margin="16,336,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Width="248" Height="48" Name="BtnNewAccount" />
        </Grid>
        <Grid Background="#FFF0F0F0" Margin="328,40,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Width="600" Height="408" Name="LBAllAccs">
            <ListBox d:ItemsSource="{d:SampleData ItemCount=5}" Margin="45,213,45,20"/>
            <TextBlock FontSize="23" HorizontalAlignment="Center" TextWrapping="Wrap" Text="Transactions" VerticalAlignment="Top" Height="31" Width="128"/>
            <ComboBox HorizontalAlignment="Left" Margin="45,116,0,0" VerticalAlignment="Top" Width="120" Name="CBTransType"/>
        </Grid>
        <TextBlock FontSize="14" HorizontalAlignment="Left" Margin="372,139,0,0" TextWrapping="Wrap" Text="TextBlock" VerticalAlignment="Top" Height="24" Width="71"/>
    </Grid>
</Window>
