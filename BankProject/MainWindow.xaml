<Window x:Class="BankProject.MainWindow" ResizeMode="NoResize"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:BankProject"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Foreground="{DynamicResource Theme_TextBrush}" Height="520" Width="930">

    <Grid Background="{DynamicResource Theme_BackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- New Account Panel-->
        <Grid Background="#FFF0F0F0" Margin="10,40,10,40" Grid.Column="0">
            <!-- Aranging elements -->
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Title -->
                <RowDefinition Height="Auto"/> <!-- First Name (Label + TB) -->
                <RowDefinition Height="Auto"/> <!-- Last Name (Label + TB) -->
                <RowDefinition Height="Auto"/> <!-- Balance (Label + TB) -->
                <RowDefinition Height="Auto"/> <!-- RadioButtons -->
                <RowDefinition Height="*"/>    <!-- Create Button -->
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" FontSize="23" HorizontalAlignment="Center" Margin="0,15,0,15" Text="New Account" />

            <!-- First Name -->
            <StackPanel Grid.Row="1" Margin="25,5,25,5">
                <TextBlock Text="First Name" FontSize="14" Name="TFirstName" Margin="0,0,0,3" />
                <TextBox FontSize="18" Height="32" Name="TBFirstName" TextChanged="TBUsernameInput_TextChanged" />
            </StackPanel>

            <!-- Last Name -->
            <StackPanel Grid.Row="2" Margin="25,5,25,5">
                <TextBlock Text="Last Name" FontSize="14" Name="TLastName" Margin="0,0,0,3" />
                <TextBox FontSize="18" Height="32" Name="TBLastName" TextChanged="TBUsernameInput_TextChanged" />
            </StackPanel>

            <!-- Balance -->
            <StackPanel Grid.Row="3" Margin="25,5,25,5">
                <TextBlock Text="Balance" FontSize="14" Name="TBalance" Margin="0,0,0,3" />
                <TextBox FontSize="18" Height="32" Name="TBBalance" TextChanged="TBBalance_TextChanged" />
            </StackPanel>

            <!-- Type of account (RadioButtons) -->
            <StackPanel Grid.Row="4" Margin="25,15,25,5">
                <RadioButton IsChecked="True" Content="Checking Account" Margin="0,0,0,8" Name="RBCheckAcc" />
                <RadioButton Content="Savings Account" Name="RBSavingAcc" />
            </StackPanel>

            <!-- Create New Account -->
            <Button Grid.Row="5" Content="Create New Account" Margin="25,0,25,20" VerticalAlignment="Bottom" Height="48" Name="BtnNewAccount" Click="BtnNewAccount_Click" />
        </Grid>

        <!-- Transactions panel -->
        <Grid Background="#FFF0F0F0" Margin="10,40,10,40" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Title -->
                <RowDefinition Height="Auto"/> <!-- Options -->
                <RowDefinition Height="*"/>    <!-- ListBox -->
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" FontSize="23" HorizontalAlignment="Center" Margin="0,15,0,15" Text="Transactions" />

            <!-- Aranging elements -->
            <Grid Grid.Row="1" Margin="45,0,45,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Type of transaction -->
                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,5,0,5">
                    <TextBlock FontSize="14" Text="Type of transaction" Margin="0,0,0,3" />
                    <ComboBox FontSize="18" Name="CBTransType" Height="32" SelectionChanged="CBTransType_SelectionChanged" />
                </StackPanel>

                <!-- Amount -->
                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,5,0,5">
                    <TextBlock FontSize="14" Text="Amount" Margin="0,0,0,3" />
                    <TextBox FontSize="18" Name="TBAmount" TextChanged="TBAmount_TextChanged" Height="32" />
                </StackPanel>

                <!-- Execute Button -->
                <Button Grid.Row="2" Grid.Column="0" Content="Execute" Height="36" Margin="0,10,0,5" Name="BtnExecute" Click="BtnExecute_Click" />
            </Grid>

            <!-- Account ListBox -->
            <ListBox Grid.Row="2" d:ItemsSource="{d:SampleData ItemCount=5}" Margin="45,10,45,20" Name="LBAllAccs" />
        </Grid>
    </Grid>
</Window>
